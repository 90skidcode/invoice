{
  "name": "@counter/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file-if-exists=../../.env.local src/server.ts",
    "start": "node --env-file-if-exists=../../.env.local dist/server.js",
    "seed": "tsx src/seed.ts",
    "seed:fresh": "tsx src/reset.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@counter/db": "workspace:*",
    "@counter/schemas": "workspace:*",
    "@counter/tax": "workspace:*",
    "@counter/utils": "workspace:*",
    "@fastify/cors": "10.0.1",
    "@fastify/helmet": "13.0.0",
    "@fastify/rate-limit": "10.2.2",
    "@fastify/jwt": "9.0.3",
    "argon2": "0.41.1",
    "bullmq": "5.34.3",
    "drizzle-orm": "0.38.4",
    "fastify": "5.2.1",
    "ioredis": "5.4.2",
    "jose": "5.9.6",
    "pino": "9.6.0",
    "qrcode": "1.5.4",
    "uuidv7": "1.0.2",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "@types/qrcode": "1.5.5",
    "pino-pretty": "13.0.0",
    "tsx": "4.19.2",
    "vitest": "2.1.8"
  }
}
