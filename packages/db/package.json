    "migrate:create": "drizzle-kit generate",
    "migrate:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@counter/utils": "workspace:*",
    "drizzle-orm": "0.38.4",
    "postgres": "3.4.5"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "drizzle-kit": "0.30.4"
  }
}
